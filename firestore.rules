rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global default-deny catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    // Checks if current user is the administrator based on the bootstrapped email: mubashirtazim2k@gmail.com
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'mubashirtazim2k@gmail.com';
    }

    // 1. Resources Path Match Block
    match /resources/{resourceId} {
      allow read: if true; // Public access for students
      
      // Verified admins can add directly, contributors can add with their registered name
      allow create: if isVerified() && isValidId(resourceId) && (
        isAdmin() || 
        (incoming().uploadedBy is string && incoming().uploadedBy.size() <= 100)
      );
      
      // Updates are constrained. Regular students can only increment likes or download counts.
      allow update: if isVerified() && isValidId(resourceId) && (
        isAdmin() || 
        incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'downloadsCount'])
      );
      
      // Only administrators can directly remove catalog files
      allow delete: if isVerified() && isValidId(resourceId) && isAdmin();
    }

    // 2. Contributors Path Match Block
    match /contributors/{contributorId} {
      allow read: if true; // Everyone can read contributor statistics
      
      allow create: if isVerified() && isValidId(contributorId) && (isAdmin() || contributorId == request.auth.uid);
      allow update: if isVerified() && isValidId(contributorId) && (
        isAdmin() || 
        (contributorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['contributionsCount', 'department', 'batch']))
      );
      allow delete: if isVerified() && isValidId(contributorId) && isAdmin();
    }

    // 3. Proposals (Moderator Actions) Path Match Block
    match /proposals/{proposalId} {
      allow read: if isVerified(); // Connected students can view log streams
      
      // Anyone verified can propose an action
      allow create: if isVerified() && isValidId(proposalId) && (
        incoming().status == 'PENDING' &&
        (incoming().contributorName is string && incoming().contributorName.size() <= 100)
      );
      
      // Admins modify status; original sender can edit reason or link if still pending
      allow update: if isVerified() && isValidId(proposalId) && (
        isAdmin() || (
          existing().status == 'PENDING' &&
          incoming().diff(existing()).affectedKeys().hasOnly(['reason', 'downloadUrl'])
        )
      );
      
      allow delete: if isVerified() && isValidId(proposalId) && isAdmin();
    }

    // 4. Passcodes Path Match Block (Locked down entirely to client-side reads)
    match /passcodes/{passcodeId} {
      allow read, write: if false;
    }
  }
}
